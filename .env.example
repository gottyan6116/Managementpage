# Supabase（フェーズ6で使用）
# Supabase ダッシュボード → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# モック ↔ Supabase の切替（false で Supabase 実装を使用、未設定/true でモック）
NEXT_PUBLIC_USE_MOCK=true

# Private app access — hash values only. Do not put passwords in this file.
APP_PASSWORD_HASH=
APP_BACKUP_PASSWORD_HASH=
AUTH_SESSION_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
