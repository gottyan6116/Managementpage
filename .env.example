# Supabase（フェーズ6で使用）
# Supabase ダッシュボード → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PPT資料ページ (/decks) の Supabase Storage 用。サーバー専用、絶対にクライアントへ露出しない。
# Supabase ダッシュボード → Project Settings → API → service_role (secret) を設定。
# private バケット「presentations」を作成しておくこと。
SUPABASE_SERVICE_ROLE_KEY=

# モック ↔ Supabase の切替（false で Supabase 実装を使用、未設定/true でモック）
NEXT_PUBLIC_USE_MOCK=true

# ==== 認証 (password-only login) ====
# 平文パスワードは絶対にここへ書かない。以下のコマンドで scrypt ハッシュを生成し、
# その結果 (salt:hash 形式) だけを Vercel の環境変数 (Preview/Production 双方) と
# ローカルの .env.local に設定する。
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" 'あなたのパスワード'
APP_PASSWORD_HASH=
APP_BACKUP_PASSWORD_HASH=

# セッション Cookie の署名鍵。以下で生成できる強力なランダム文字列を設定する。
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SESSION_SECRET=
